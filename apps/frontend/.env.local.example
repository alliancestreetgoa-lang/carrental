# ============================================================
# Alliance Car Rental — Frontend Environment Variables
# Copy to .env.local and fill in values.
# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD TIME — rebuild
# the app after changing them; they are not secret.
# ============================================================

NEXT_PUBLIC_API_URL="https://your-backend-domain/api"
NEXT_PUBLIC_SOCKET_URL="https://your-backend-domain"
NEXT_PUBLIC_SITE_URL="https://your-frontend-domain"
