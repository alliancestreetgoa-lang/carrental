# ============================================================
# Alliance Car Rental — Backend Environment Variables
# Copy to .env and fill in values before starting the server.
# ============================================================

# ------ Core ------------------------------------------------
DATABASE_URL="postgresql://user:pass@host:5432/alliance_car_rental?schema=public"
JWT_SECRET="change-me-min-32-chars-long-secret-value"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=production

# CORS + generated link origin — set to the real frontend domain in production
FRONTEND_URL="https://your-frontend-domain"

# ------ Cloudinary (document/image uploads) -----------------
# Optional — file uploads return 503 until these are set
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------ Payments --------------------------------------------
# Optional — app runs in demo/mock mode until set
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# ------ Email (SMTP via nodemailer) -------------------------
# Optional — email actions log to console until set
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ------ Messaging -------------------------------------------
# Optional — logs to console until set
WHATSAPP_TOKEN=
SMS_PROVIDER=
