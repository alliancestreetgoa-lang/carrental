generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Role {
  SUPER_ADMIN
  STAFF
  ACCOUNTANT
}

enum CarStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
  OUT_OF_SERVICE
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
  LPG
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum BookingStatus {
  RESERVED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

enum ExpenseCategory {
  FUEL
  SERVICE
  REPAIR
  INSURANCE
  CLEANING
  EMI
  OTHER
}

enum DocumentType {
  LICENSE
  AADHAAR
  PASSPORT
  RC
  INSURANCE
  POLLUTION
  PHOTO
  OTHER
}

// ============================================================
// Models
// ============================================================

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  mobile    String?
  password  String
  role      Role      @default(STAFF)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model Car {
  id                 String       @id @default(cuid())
  carName            String
  brand              String
  model              String
  year               Int
  registrationNumber String       @unique
  chassisNumber      String       @unique
  fuelType           FuelType     @default(PETROL)
  transmission       Transmission @default(MANUAL)
  seatingCapacity    Int          @default(5)
  dailyRent          Decimal      @db.Decimal(10, 2)
  weeklyRent         Decimal?     @db.Decimal(10, 2)
  monthlyRent        Decimal?     @db.Decimal(10, 2)
  securityDeposit    Decimal      @default(0) @db.Decimal(10, 2)
  insuranceExpiry    DateTime?
  pollutionExpiry    DateTime?
  rcExpiry           DateTime?
  currentKilometer   Int          @default(0)
  status             CarStatus    @default(AVAILABLE)
  images             String[]     @default([])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  bookings  Booking[]
  expenses  Expense[]
  documents Document[]

  @@index([status])
  @@index([brand])
  @@index([fuelType])
  @@index([deletedAt])
  @@map("cars")
}

model Customer {
  id               String    @id @default(cuid())
  fullName         String
  mobile           String
  whatsapp         String?
  email            String?   @unique
  address          String?
  licenseNumber    String    @unique
  licenseExpiry    DateTime?
  aadhaarNumber    String?   @unique
  emergencyContact String?
  notes            String?
  blacklisted      Boolean   @default(false)
  blacklistReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  bookings  Booking[]
  documents Document[]

  @@index([mobile])
  @@index([fullName])
  @@index([blacklisted])
  @@index([deletedAt])
  @@map("customers")
}

model Booking {
  id              String        @id @default(cuid())
  customerId      String
  carId           String
  pickupDate      DateTime
  returnDate      DateTime
  pickupLocation  String?
  dropLocation    String?
  bookingStatus   BookingStatus @default(RESERVED)
  fuelLevel       String?
  returnFuelLevel String?
  startKilometer  Int?
  endKilometer    Int?
  actualReturnDate DateTime?
  advancePayment  Decimal       @default(0) @db.Decimal(10, 2)
  securityDeposit Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @default(0) @db.Decimal(10, 2)
  lateFee         Decimal       @default(0) @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  customer  Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  car       Car        @relation(fields: [carId], references: [id], onDelete: Restrict)
  payments  Payment[]
  agreement Agreement?

  @@index([customerId])
  @@index([carId])
  @@index([bookingStatus])
  @@index([pickupDate])
  @@index([returnDate])
  @@index([deletedAt])
  @@map("bookings")
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH)
  paymentDate   DateTime      @default(now())
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([paymentMethod])
  @@index([paymentDate])
  @@index([deletedAt])
  @@map("payments")
}

model Expense {
  id          String          @id @default(cuid())
  carId       String
  category    ExpenseCategory @default(OTHER)
  amount      Decimal         @db.Decimal(10, 2)
  expenseDate DateTime        @default(now())
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
  @@index([category])
  @@index([expenseDate])
  @@index([deletedAt])
  @@map("expenses")
}

model Agreement {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  agreementNumber String    @unique
  pdfUrl          String?
  signed          Boolean   @default(false)
  signedAt        DateTime?
  signatureData   String?
  signatoryName   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([signed])
  @@index([deletedAt])
  @@map("agreements")
}

model Document {
  id         String       @id @default(cuid())
  customerId String?
  carId      String?
  type       DocumentType @default(OTHER)
  fileUrl    String
  ocrText    String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  car      Car?      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([carId])
  @@index([type])
  @@index([deletedAt])
  @@map("documents")
}
